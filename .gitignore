# Synalyze Web PHP - .gitignore

# Database files
database/*.sqlite
database/*.sqlite-journal
database/*.sqlite-wal
database/*.sqlite-shm
*.db
*.sqlite

# Composer dependencies
/vendor/
composer.lock

# Assets and Uploads
public/uploads/
.env
config/local.php

# PHP & Server Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Text Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.antigravityignore
